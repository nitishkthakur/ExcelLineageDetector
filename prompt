## EXAMPLE

**Input:**

```sql
WITH orders_filtered AS (
    SELECT order_id, customer_id, amount
    FROM orders
    WHERE status = 'completed'
),
customer_orders AS (
    SELECT o.order_id, o.amount, c.region
    FROM orders_filtered o
    INNER JOIN customers c ON o.customer_id = c.customer_id
),
regional_revenue AS (
    SELECT region, SUM(amount) AS total_revenue
    FROM customer_orders
    GROUP BY region
)
SELECT region, total_revenue
FROM regional_revenue
WHERE total_revenue > 10000;
```

**Output:**

```json
{
  "d": [
    {
      "id": "layer_1",
      "t": "orders pipeline",
      "n": [
        ["n1",  "S", "orders",           ["order_id","customer_id","amount","status"]],
        ["op1", "X", "FILTER",           "status='completed'"],
        ["n2",  "C", "orders_filtered",  ["order_id","customer_id","amount"]],
        ["n3",  "S", "customers",        ["customer_id","region"]],
        ["op2", "X", "JOIN",             "o.customer_id=c.customer_id"],
        ["n4",  "C", "customer_orders",  ["order_id","amount","region"]],
        ["op3", "X", "AGG",              "GROUP BY region,SUM(amount)"],
        ["n5",  "C", "regional_revenue", ["region","total_revenue"]],
        ["op4", "X", "FILTER",           "total_revenue>10000"],
        ["n6",  "O", "final_output",     ["region","total_revenue"]]
      ],
      "e": [
        "n1>op1","op1>n2","n2>op2","n3>op2",
        "op2>n4","n4>op3","op3>n5","n5>op4","op4>n6"
      ]
    }
  ],
  "x": []
}
```

